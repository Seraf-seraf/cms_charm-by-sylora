{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header"><div class="container-fluid"><div class="pull-right"><button type="submit" form="form-metrica" class="btn btn-primary" title="{{ button_save }}"><i class="fa fa-save"></i></button><a href="{{ cancel }}" class="btn btn-default" title="{{ button_cancel }}"><i class="fa fa-reply"></i></a></div><h1>{{ heading_title }}</h1></div></div>
  <div class="container-fluid">
    {% if error_warning %}<div class="alert alert-danger">{{ error_warning }}</div>{% endif %}
    <div class="panel panel-default"><div class="panel-heading"><h3 class="panel-title">{{ text_edit }}</h3></div><div class="panel-body">
      <form action="{{ action }}" method="post" id="form-metrica" class="form-horizontal">
        <div class="form-group required"><label class="col-sm-3 control-label" for="input-counter">{{ entry_counter }}</label><div class="col-sm-9"><input name="analytics_yandex_metrica_counter" value="{{ analytics_yandex_metrica_counter }}" id="input-counter" class="form-control"><p class="help-block">{{ help_counter }}</p>{% if error_counter %}<div class="text-danger">{{ error_counter }}</div>{% endif %}</div></div>
        {% for field, label in {'webvisor': entry_webvisor, 'ecommerce': entry_ecommerce, 'status': entry_status} %}<div class="form-group"><label class="col-sm-3 control-label" for="input-{{ field }}">{{ label }}</label><div class="col-sm-9"><select name="analytics_yandex_metrica_{{ field }}" id="input-{{ field }}" class="form-control"><option value="1"{% if attribute(_context, 'analytics_yandex_metrica_' ~ field) %} selected{% endif %}>{{ text_enabled }}</option><option value="0"{% if not attribute(_context, 'analytics_yandex_metrica_' ~ field) %} selected{% endif %}>{{ text_disabled }}</option></select></div></div>{% endfor %}
        <div class="alert alert-info">{{ help_goals }}</div>
      </form>
    </div></div>
  </div>
</div>
{{ footer }}
