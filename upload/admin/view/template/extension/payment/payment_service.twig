{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-payment" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-payment" class="form-horizontal">
          <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-api-url"><span data-toggle="tooltip" title="{{ help_api_url }}">{{ entry_api_url }}</span></label>
            <div class="col-sm-10">
              <input type="text" name="payment_payment_service_api_url" value="{{ payment_payment_service_api_url }}" placeholder="{{ entry_api_url }}" id="input-api-url" class="form-control" />
              {% if error_api_url %}
              <div class="text-danger">{{ error_api_url }}</div>
              {% endif %}
            </div>
          </div>
          <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-api-key">{{ entry_api_key }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_payment_service_api_key" value="{{ payment_payment_service_api_key }}" placeholder="{{ entry_api_key }}" id="input-api-key" class="form-control" />
              {% if error_api_key %}
              <div class="text-danger">{{ error_api_key }}</div>
              {% endif %}
            </div>
          </div>
          <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-shared-secret"><span data-toggle="tooltip" title="{{ help_shared_secret }}">{{ entry_shared_secret }}</span></label>
            <div class="col-sm-10">
              <input type="password" name="payment_payment_service_shared_secret" value="{{ payment_payment_service_shared_secret }}" placeholder="{{ entry_shared_secret }}" id="input-shared-secret" class="form-control" autocomplete="new-password" />
              {% if error_shared_secret %}
              <div class="text-danger">{{ error_shared_secret }}</div>
              {% endif %}
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-callback-url"><span data-toggle="tooltip" title="{{ help_callback_url }}">{{ entry_callback_url }}</span></label>
            <div class="col-sm-10">
              <input type="text" value="{{ callback_url }}" id="input-callback-url" class="form-control" readonly="readonly" />
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-success-url"><span data-toggle="tooltip" title="{{ help_success_url }}">{{ entry_success_url }}</span></label>
            <div class="col-sm-10">
              <input type="text" value="{{ success_url }}" id="input-success-url" class="form-control" readonly="readonly" />
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-fail-url"><span data-toggle="tooltip" title="{{ help_fail_url }}">{{ entry_fail_url }}</span></label>
            <div class="col-sm-10">
              <input type="text" value="{{ fail_url }}" id="input-fail-url" class="form-control" readonly="readonly" />
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-total"><span data-toggle="tooltip" title="{{ help_total }}">{{ entry_total }}</span></label>
            <div class="col-sm-10">
              <input type="text" name="payment_payment_service_total" value="{{ payment_payment_service_total }}" placeholder="{{ entry_total }}" id="input-total" class="form-control" />
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-pending-status">{{ entry_pending_status }}</label>
            <div class="col-sm-10">
              <select name="payment_payment_service_pending_status_id" id="input-pending-status" class="form-control">
                {% for order_status in order_statuses %}
                <option value="{{ order_status.order_status_id }}"{% if order_status.order_status_id == payment_payment_service_pending_status_id %} selected="selected"{% endif %}>{{ order_status.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-success-status">{{ entry_success_status }}</label>
            <div class="col-sm-10">
              <select name="payment_payment_service_success_status_id" id="input-success-status" class="form-control">
                {% for order_status in order_statuses %}
                <option value="{{ order_status.order_status_id }}"{% if order_status.order_status_id == payment_payment_service_success_status_id %} selected="selected"{% endif %}>{{ order_status.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-failed-status">{{ entry_failed_status }}</label>
            <div class="col-sm-10">
              <select name="payment_payment_service_failed_status_id" id="input-failed-status" class="form-control">
                {% for order_status in order_statuses %}
                <option value="{{ order_status.order_status_id }}"{% if order_status.order_status_id == payment_payment_service_failed_status_id %} selected="selected"{% endif %}>{{ order_status.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-canceled-status">{{ entry_canceled_status }}</label>
            <div class="col-sm-10">
              <select name="payment_payment_service_canceled_status_id" id="input-canceled-status" class="form-control">
                {% for order_status in order_statuses %}
                <option value="{{ order_status.order_status_id }}"{% if order_status.order_status_id == payment_payment_service_canceled_status_id %} selected="selected"{% endif %}>{{ order_status.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-refunded-status">{{ entry_refunded_status }}</label>
            <div class="col-sm-10">
              <select name="payment_payment_service_refunded_status_id" id="input-refunded-status" class="form-control">
                {% for order_status in order_statuses %}
                <option value="{{ order_status.order_status_id }}"{% if order_status.order_status_id == payment_payment_service_refunded_status_id %} selected="selected"{% endif %}>{{ order_status.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-geo-zone">{{ entry_geo_zone }}</label>
            <div class="col-sm-10">
              <select name="payment_payment_service_geo_zone_id" id="input-geo-zone" class="form-control">
                <option value="0">{{ text_all_zones }}</option>
                {% for geo_zone in geo_zones %}
                <option value="{{ geo_zone.geo_zone_id }}"{% if geo_zone.geo_zone_id == payment_payment_service_geo_zone_id %} selected="selected"{% endif %}>{{ geo_zone.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="payment_payment_service_status" id="input-status" class="form-control">
                {% if payment_payment_service_status %}
                <option value="1" selected="selected">{{ text_enabled }}</option>
                <option value="0">{{ text_disabled }}</option>
                {% else %}
                <option value="1">{{ text_enabled }}</option>
                <option value="0" selected="selected">{{ text_disabled }}</option>
                {% endif %}
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-sort-order">{{ entry_sort_order }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_payment_service_sort_order" value="{{ payment_payment_service_sort_order }}" placeholder="{{ entry_sort_order }}" id="input-sort-order" class="form-control" />
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-timestamp-skew"><span data-toggle="tooltip" title="{{ help_timestamp_skew }}">{{ entry_timestamp_skew }}</span></label>
            <div class="col-sm-10">
              <input type="text" name="payment_payment_service_timestamp_skew" value="{{ payment_payment_service_timestamp_skew }}" placeholder="{{ entry_timestamp_skew }}" id="input-timestamp-skew" class="form-control" />
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
