{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header"><div class="container-fluid"><div class="pull-right"><button type="submit" form="form-russian-post" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button> <a href="{{ cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a></div><h1>{{ heading_title }}</h1><ul class="breadcrumb">{% for breadcrumb in breadcrumbs %}<li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>{% endfor %}</ul></div></div>
  <div class="container-fluid">{% if error_warning %}<div class="alert alert-danger">{{ error_warning }}</div>{% endif %}
    <div class="panel panel-default"><div class="panel-heading"><h3 class="panel-title"><i class="fa fa-truck"></i> {{ text_edit }}</h3></div><div class="panel-body">
      <form action="{{ action }}" method="post" id="form-russian-post" class="form-horizontal">
        {% set fields = {'widget_id': entry_widget_id, 'origin_postcode': entry_origin_postcode, 'api_url': entry_api_url, 'default_weight': entry_default_weight, 'timeout': entry_timeout, 'sort_order': entry_sort_order} %}
        {% for name,label in fields %}<div class="form-group"><label class="col-sm-3 control-label" for="rp-{{ name }}">{{ label }}</label><div class="col-sm-9"><input class="form-control" id="rp-{{ name }}" name="shipping_russian_post_{{ name }}" value="{{ attribute(_context, 'shipping_russian_post_' ~ name) }}"></div></div>{% endfor %}
        {% for name,label in {'token': entry_token, 'login': entry_login, 'password': entry_password} %}<div class="form-group"><label class="col-sm-3 control-label" for="rp-{{ name }}">{{ label }}</label><div class="col-sm-9"><input type="password" autocomplete="new-password" class="form-control" id="rp-{{ name }}" name="shipping_russian_post_{{ name }}" value="">{% if attribute(_context, 'shipping_russian_post_' ~ name ~ '_configured') %}<p class="help-block">{{ text_secret_saved }}</p>{% endif %}</div></div>{% endfor %}
        <div class="form-group"><label class="col-sm-3 control-label">{{ entry_dimensions }}</label><div class="col-sm-3"><input class="form-control" name="shipping_russian_post_default_length" value="{{ shipping_russian_post_default_length }}" placeholder="Длина"></div><div class="col-sm-3"><input class="form-control" name="shipping_russian_post_default_width" value="{{ shipping_russian_post_default_width }}" placeholder="Ширина"></div><div class="col-sm-3"><input class="form-control" name="shipping_russian_post_default_height" value="{{ shipping_russian_post_default_height }}" placeholder="Высота"></div></div>
        <div class="form-group"><label class="col-sm-3 control-label">{{ entry_status }}</label><div class="col-sm-9"><select class="form-control" name="shipping_russian_post_status"><option value="1"{% if shipping_russian_post_status %} selected{% endif %}>{{ text_enabled }}</option><option value="0"{% if not shipping_russian_post_status %} selected{% endif %}>{{ text_disabled }}</option></select></div></div>
      </form>
    </div></div>
  </div>
</div>{{ footer }}
