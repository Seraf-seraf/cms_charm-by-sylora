{{ header }}
<div id="product-search" class="container">
  <div class="row">{{ column_left }}
    {% if column_left and column_right %}
    {% set class = 'col-sm-6' %}
    {% elseif column_left or column_right %}
    {% set class = 'col-sm-9' %}
    {% else %}
    {% set class = 'col-sm-12' %}
    {% endif %}
    <div id="content" class="{{ class }}">{{ content_top }}
      <header class="catalog-head">
        <p class="sylora-eyebrow">Акции</p>
        <h1>{{ heading_title }}</h1>
      </header>
      {% if products %}
      <div class="catalog-toolbar">
        <div class="catalog-toolbar__count">{{ results }}</div>
        <div class="catalog-toolbar__controls">
          <div class="form-group input-group input-group-sm">
            <label class="input-group-addon" for="input-sort">Сортировка</label>
            <select id="input-sort" class="form-control" onchange="location = this.value;">
              {% for sorts in sorts %}
              {% if sorts.value == '%s-%s'|format(sort, order) %}
              <option value="{{ sorts.href }}" selected="selected">{{ sorts.text }}</option>
              {% else %}
              <option value="{{ sorts.href }}">{{ sorts.text }}</option>
              {% endif %}
              {% endfor %}
            </select>
          </div>
          <div class="form-group input-group input-group-sm">
            <label class="input-group-addon" for="input-limit">Показать</label>
            <select id="input-limit" class="form-control" onchange="location = this.value;">
              {% for limits in limits %}
              {% if limits.value == limit %}
              <option value="{{ limits.href }}" selected="selected">{{ limits.text }}</option>
              {% else %}
              <option value="{{ limits.href }}">{{ limits.text }}</option>
              {% endif %}
              {% endfor %}
            </select>
          </div>
        </div>
      </div>
      <div class="catalog-grid"> {% for product in products %}
        <article class="product-layout product-grid catalog-card">
          <div class="product-thumb">
            <a class="catalog-card__image" href="{{ product.href }}">
              {% if product.badge %}
              <span class="catalog-card__badge {{ product.badge_class }}">{{ product.badge }}</span>
              {% endif %}
              <picture>
                {% for source in product.image.sources %}
                <source srcset="{{ source.src }}" type="{{ source.type }}">
                {% endfor %}
                <img class="catalog-card__image-primary" src="{{ product.image.src }}" alt="{{ product.name }}" title="{{ product.name }}" width="{{ product.image.width }}" height="{{ product.image.height }}" loading="lazy" decoding="async" />
              </picture>
              {% if product.hover_image.src %}
              <picture>
                {% for source in product.hover_image.sources %}
                <source srcset="{{ source.src }}" type="{{ source.type }}">
                {% endfor %}
                <img class="catalog-card__image-hover" src="{{ product.hover_image.src }}" alt="{{ product.name }} - дополнительное фото" title="{{ product.name }}" width="{{ product.hover_image.width }}" height="{{ product.hover_image.height }}" loading="lazy" decoding="async" />
              </picture>
              {% endif %}
            </a>
            <div class="catalog-card__body">
              <div class="caption">
                <p class="catalog-card__stock {{ product.stock_class }}">{{ product.stock }}</p>
                <h2><a href="{{ product.href }}">{{ product.name }}</a></h2>
                <p class="catalog-card__description">{{ product.description }}</p>
                {% if product.price %}
                <p class="price"> {% if not product.special %}
                  {{ product.price }}
                  {% else %} <span class="price-new">{{ product.special }}</span> <span class="price-old">{{ product.price }}</span> {% endif %}
                  {% if product.tax %} <span class="price-tax">{{ text_tax }} {{ product.tax }}</span> {% endif %} </p>
                {% endif %}
                {% if product.rating %}
                <div class="rating">
                  {% for i in 1..5 %}
                  {% if product.rating < i %} <span class="fa fa-stack"><i class="fa fa-star-o fa-stack-2x"></i></span> {% else %} <span class="fa fa-stack"><i class="fa fa-star fa-stack-2x"></i><i class="fa fa-star-o fa-stack-2x"></i></span> {% endif %}
                  {% endfor %}
                </div>
                {% endif %} </div>
              <div class="button-group catalog-card__actions">
                <button type="button" class="catalog-card__cart" onclick="cart.add('{{ product.product_id }}', '{{ product.minimum }}');"><i class="fa fa-shopping-cart"></i> <span>В корзину</span></button>
                <a class="catalog-card__more" href="{{ product.href }}">Подробнее</a>
                <button type="button" class="catalog-card__icon" data-toggle="tooltip" title="В избранное" aria-label="В избранное" onclick="wishlist.add('{{ product.product_id }}');"><i class="fa fa-heart"></i></button>
              </div>
            </div>
          </div>
        </article>
        {% endfor %} </div>
      <div class="row">
        <div class="col-sm-6 text-left">{{ pagination }}</div>
      </div>
      {% else %}
      <p class="catalog-empty">{{ text_empty }}</p>
      <div class="buttons">
        <div class="pull-right"><a href="{{ continue }}" class="btn btn-primary">{{ button_continue }}</a></div>
      </div>
      {% endif %}
      {{ content_bottom }}</div>
    {{ column_right }}</div>
</div>
{{ footer }}
