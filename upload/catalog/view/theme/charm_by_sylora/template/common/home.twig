{{ header }}
<main id="common-home">
  <section class="sylora-hero">
    <div class="container sylora-hero__grid">
      <div class="sylora-hero__content">
        <p class="sylora-eyebrow">Charm by Sylora</p>
        <h1>{{ heading_title }}</h1>
        <p>Серьги, браслеты, подвески и комплекты для повседневных образов, подарков и небольших личных ритуалов.</p>
        <div class="sylora-actions">
          <a class="btn btn-primary btn-lg" href="{{ catalog }}">Смотреть каталог</a>
          <a class="sylora-link" href="{{ about }}">О бренде</a>
        </div>
      </div>
      <div class="sylora-hero__media" aria-label="Украшения ручной работы">
        {% if hero_products %}
        <div class="sylora-product-slider">
          <div class="sylora-product-slider__track">
            {% for product in hero_products %}
            <a class="sylora-product-slide" href="{{ product.href }}">
              <picture>
                {% for source in product.image.sources %}
                <source srcset="{{ source.src }}" type="{{ source.type }}">
                {% endfor %}
                <img src="{{ product.image.src }}" alt="{{ product.name }}" width="{{ product.image.width }}" height="{{ product.image.height }}" loading="{% if loop.first %}eager{% else %}lazy{% endif %}" decoding="async">
              </picture>
              <span>{{ product.name }}</span>
            </a>
            {% endfor %}
            {% for product in hero_products %}
            <a class="sylora-product-slide" href="{{ product.href }}" aria-hidden="true" tabindex="-1">
              <picture>
                {% for source in product.image.sources %}
                <source srcset="{{ source.src }}" type="{{ source.type }}">
                {% endfor %}
                <img src="{{ product.image.src }}" alt="" width="{{ product.image.width }}" height="{{ product.image.height }}" loading="lazy" decoding="async">
              </picture>
              <span>{{ product.name }}</span>
            </a>
            {% endfor %}
          </div>
        </div>
        {% else %}
        <div class="sylora-product-slider sylora-product-slider--fallback">
          <div class="sylora-product-slider__track">
            <img src="image/catalog/sylora/jewelry-collection.png" alt="Коллекция украшений ручной работы Charm by Sylora" width="420" height="315" loading="eager" decoding="async">
            <img src="image/catalog/sylora/jewelry-collection.png" alt="Детали авторских украшений в розовых и зеленых оттенках" width="420" height="315" loading="lazy" decoding="async">
            <img src="image/catalog/sylora/jewelry-collection.png" alt="" width="420" height="315" loading="lazy" decoding="async" aria-hidden="true">
            <img src="image/catalog/sylora/jewelry-collection.png" alt="" width="420" height="315" loading="lazy" decoding="async" aria-hidden="true">
          </div>
        </div>
        {% endif %}
      </div>
    </div>
  </section>

  <section class="container sylora-section">
    <div class="sylora-section__head">
      <h2>Категории</h2>
      <a href="{{ catalog }}">Все украшения</a>
    </div>
    {% if home_categories %}
    <div class="sylora-category-grid">
      {% for category in home_categories %}
      <a class="sylora-category-card" href="{{ category.href }}">
        <span>{{ category.name }}</span>
        <small>{{ category.description }}</small>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <p class="sylora-empty">Категории появятся здесь после настройки каталога.</p>
    {% endif %}
  </section>

  <section class="container sylora-section">
    <div class="sylora-section__head">
      <h2>Избранные украшения</h2>
      <a href="{{ catalog }}">Перейти в каталог</a>
    </div>
    {% if featured_products %}
    <div class="catalog-grid catalog-grid--home">
      {% for product in featured_products %}
      <article class="product-layout product-grid catalog-card">
        <div class="product-thumb">
          <a class="catalog-card__image" href="{{ product.href }}">
            {% if product.badge %}
            <span class="catalog-card__badge {{ product.badge_class }}">{{ product.badge }}</span>
            {% endif %}
            <picture>
              {% for source in product.image.sources %}
              <source srcset="{{ source.src }}" type="{{ source.type }}">
              {% endfor %}
              <img class="catalog-card__image-primary" src="{{ product.image.src }}" alt="{{ product.name }}" title="{{ product.name }}" width="{{ product.image.width }}" height="{{ product.image.height }}" loading="lazy" decoding="async" />
            </picture>
          </a>
          <div class="catalog-card__body">
            <div class="caption">
              <p class="catalog-card__stock {{ product.stock_class }}">{{ product.stock }}</p>
              <h3><a href="{{ product.href }}">{{ product.name }}</a></h3>
              {% if product.price %}
              <p class="price">{% if product.special %}<span class="price-new">{{ product.special }}</span> <span class="price-old">{{ product.price }}</span>{% else %}{{ product.price }}{% endif %}</p>
              {% endif %}
            </div>
            <div class="button-group catalog-card__actions">
              <button type="button" class="catalog-card__cart" onclick="cart.add('{{ product.product_id }}');"><i class="fa fa-shopping-cart"></i> <span>В корзину</span></button>
              <a class="catalog-card__more" href="{{ product.href }}">Подробнее</a>
              <button type="button" class="catalog-card__icon" data-toggle="tooltip" title="В избранное" aria-label="В избранное" onclick="wishlist.add('{{ product.product_id }}');"><i class="fa fa-heart"></i></button>
            </div>
          </div>
        </div>
      </article>
      {% endfor %}
    </div>
    {% else %}
    <p class="sylora-empty">Товары появятся здесь после добавления ассортимента.</p>
    {% endif %}
  </section>

  <section class="sylora-benefits">
    <div class="container sylora-benefits__grid">
      <div><strong>Ручная работа</strong><span>Каждое изделие собирается небольшими партиями.</span></div>
      <div><strong>Бережная упаковка</strong><span>Украшения готовы к подарку сразу после получения.</span></div>
      <div><strong>Ограниченные коллекции</strong><span>Повторы возможны только при наличии материалов.</span></div>
      <div><strong>Доставка по России</strong><span>Условия доставки видны до оформления заказа.</span></div>
    </div>
  </section>

  <section class="container sylora-about-teaser">
    <div>
      <p class="sylora-eyebrow">О мастере</p>
      <h2>Украшения с теплым характером</h2>
      <p>Charm by Sylora вырос из любви к аккуратным деталям, спокойным природным оттенкам и вещам, которые приятно носить каждый день. В работе важны баланс формы, качество материалов и ощущение личного выбора.</p>
      <a class="sylora-link" href="{{ about }}">Читать историю</a>
    </div>
    <img src="image/catalog/sylora/jewelry-collection.png" alt="Украшения ручной работы на рабочем столе мастера" width="420" height="315" loading="lazy" decoding="async">
  </section>

  <section class="container sylora-seo">
    <h2>Авторские украшения ручной работы</h2>
    <p>В интернет-магазине Charm by Sylora можно выбрать ручные украшения для себя и в подарок: серьги, браслеты, подвески, колье и комплекты в спокойной современной эстетике. В коллекциях используются натуральные оттенки, мягкие сочетания розового, зеленого и теплого коричневого, аккуратная фурнитура и материалы, которые помогают изделию выглядеть деликатно и уместно в повседневном образе. Каждое украшение создается небольшими партиями, поэтому ассортимент легко обновлять новинками, сезонными подборками и подарочными наборами. Заказ можно оформить через каталог и корзину, а условия оплаты, доставки и возврата вынесены в понятные разделы сайта.</p>
  </section>

  <div class="container">
    <div class="row">{{ column_left }}
    {% if column_left and column_right %}
    {% set class = 'col-sm-6' %}
    {% elseif column_left or column_right %}
    {% set class = 'col-sm-9' %}
    {% else %}
    {% set class = 'col-sm-12' %}
    {% endif %}
    <div id="content" class="{{ class }}">{{ content_top }}{{ content_bottom }}</div>
    {{ column_right }}</div>
  </div>
</main>
{{ footer }}
