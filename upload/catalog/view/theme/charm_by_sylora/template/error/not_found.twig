{{ header }}
<div id="error-not-found" class="container">
  <ul class="breadcrumb">
    {% for breadcrumb in breadcrumbs %}
    <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
    {% endfor %}
  </ul>
  <div class="row">{{ column_left }}
    {% if column_left and column_right %}
    {% set class = 'col-sm-6' %}
    {% elseif column_left or column_right %}
    {% set class = 'col-sm-9' %}
    {% else %}
    {% set class = 'col-sm-12' %}
    {% endif %}
    <div id="content" class="{{ class }}">{{ content_top }}
      <section class="not-found-page">
        <p class="sylora-eyebrow">404</p>
        <h1>{{ heading_title }}</h1>
        <p>{{ text_error }}</p>
        <div class="not-found-page__actions">
          <a href="{{ catalog }}" class="btn btn-primary">{{ text_catalog }}</a>
          <a href="{{ continue }}" class="btn btn-default">{{ text_home }}</a>
          <a href="{{ contact }}" class="btn btn-link">{{ text_contact }}</a>
        </div>
      </section>
      {{ content_bottom }}</div>
    {{ column_right }}</div>
</div>
{{ footer }}
